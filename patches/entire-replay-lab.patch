+		".hcl",
+		".hpp",
+		".hs",
+		".hxx",
+		".java",
+		".js",
+		".jsx",
+		".kt",
+		".kts",
+		".lua",
+		".mli",
+		".ml",
+		".php",
+		".proto",
+		".py",
+		".rb",
+		".rs",
+		".scala",
+		".sc",
