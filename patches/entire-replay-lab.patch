+func TestReplayEvalAllAgentsExpandsEntireCoderList(t *testing.T) {
+	_, cpID, _, _ := newReplayRepo(t)
+	restoreRunner := replayRunnerFor
+	replayRunnerFor = func(agentName string) *replayRunnerFunc {
+		agentName = canonicalReplayAgentName(agentName)
+		if slices.Contains(replayLaunchableAgents, agentName) {
+			return &replayRunnerFunc{name: agentName, fn: func(_ context.Context, req ReplayRunnerRequest) (ReplayRunnerResult, error) {
+				if err := os.WriteFile(filepath.Join(req.WorktreePath, replayFixtureFile), []byte(replayTargetContent), 0o644); err != nil {
+					return ReplayRunnerResult{}, err
+				}
+				return ReplayRunnerResult{Output: "fake replay completed"}, nil
+			}}
+		}
+		return nil
+	}
+	defer func() { replayRunnerFor = restoreRunner }()
+	restoreCommand := replayCommandForAgent
+	replayCommandForAgent = func(string) string { return "" }
+	defer func() { replayCommandForAgent = restoreCommand }()
+
+	eval, err := runReplayEval(context.Background(), replayEvalOptions{
+		Checkpoints: []string{cpID},
+		Agents:      []string{replayAgentAll},
+	})
+	if err != nil {
+		t.Fatalf("runReplayEval() error = %v", err)
+	}
+	knownAgents := replayKnownAgents()
+	if !slices.Equal(eval.Agents, knownAgents) {
+		t.Fatalf("agents = %v, want %v", eval.Agents, knownAgents)
+	}
+	if len(eval.Runs) != len(knownAgents) {
+		t.Fatalf("runs = %d, want %d", len(eval.Runs), len(knownAgents))
+	}
+
+	passed := 0
+	skipped := 0
+	for _, run := range eval.Runs {
+		switch run.Status {
+		case replayStatusPassed:
+			passed++
+		case replayStatusSkipped:
+			skipped++
+			if !strings.Contains(run.Error, "supported by Entire but is not launchable") {
+				t.Fatalf("skipped error = %q", run.Error)
+			}
+		default:
+			t.Fatalf("unexpected run status = %+v", run)
+		}
+	}
+	if passed != len(replayLaunchableAgents) {
+		t.Fatalf("passed runs = %d, want %d", passed, len(replayLaunchableAgents))
+	}
+	if skipped != len(knownAgents)-len(replayLaunchableAgents) {
+		t.Fatalf("skipped runs = %d, want %d", skipped, len(knownAgents)-len(replayLaunchableAgents))
+	}
+
+	var out bytes.Buffer
+	if err := writeReplayJSON(&out, eval); err != nil {
+		t.Fatalf("writeReplayJSON() error = %v", err)
+	}
+	if strings.Contains(out.String(), `"changed_files": null`) || strings.Contains(out.String(), `"files_touched": null`) {
+		t.Fatalf("all-agent eval JSON contains null arrays:\n%s", out.String())
+	}
+}
