+func replayGitForTest(t *testing.T, repoRoot string, args ...string) string {
+	t.Helper()
+	out, err := replayGit(context.Background(), repoRoot, args...)
+	if err != nil {
+		t.Fatalf("git %v: %v", args, err)
+	}
+	return out
+}
