+	}
+	defer repo.Close()
+	infos, err := checkpoint.NewGitStore(repo).ListCommitted(ctx)
+	if err != nil {
+		return nil, fmt.Errorf("list committed checkpoints: %w", err)
+	}
+	if limit > len(infos) {
+		limit = len(infos)
+	}
+	out := make([]string, 0, limit)
+	for i := range limit {
+		out = append(out, infos[i].CheckpointID.String())
+	}
+	return out, nil
