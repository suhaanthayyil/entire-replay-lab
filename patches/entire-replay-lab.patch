+
+func orderReplayAgents(agentNames []string) []string {
+	seen := make(map[string]struct{}, len(agentNames))
+	for _, name := range agentNames {
+		name = canonicalReplayAgentName(name)
+		if name == "" || name == replayAgentAll {
+			continue
+		}
+		seen[name] = struct{}{}
+	}
+
+	ordered := make([]string, 0, len(seen))
+	for _, name := range replayLaunchableAgents {
+		if _, ok := seen[name]; ok {
+			ordered = append(ordered, name)
+			delete(seen, name)
+		}
+	}
+
+	remaining := make([]string, 0, len(seen))
+	for name := range seen {
+		remaining = append(remaining, name)
+	}
+	sort.Strings(remaining)
+	return append(ordered, remaining...)
+}
